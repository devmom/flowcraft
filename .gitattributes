# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Config / data
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Scripts (Windows batch is CRLF, PowerShell is LF)
*.bat text eol=crlf
*.ps1 text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.db binary
*.sqlite3 binary
*.pyd binary
